# Основные настройки приложения
APP_NAME=AutoBaza Parser API
APP_VERSION=1.0.0
DEBUG=false

# Настройки логирования
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Настройки для парсинга
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=1.0

# Настройки для Autohub
AUTOHUB_BASE_URL=https://www.autohubauction.co.kr
AUTOHUB_LIST_URL=https://www.autohubauction.co.kr/newfront/receive/rc/receive_rc_list.do

# User Agent для запросов
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Настройки для cache (если понадобится)
CACHE_TTL=300 